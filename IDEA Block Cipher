def idea_encrypt(text, key):
    result = ""
    for ch in text:
        result += chr((ord(ch) * key) % 256)
    return result

def idea_decrypt(cipher, key):
    result = ""
    for ch in cipher:
        result += chr((ord(ch) // key) % 256)
    return result

text = input("Enter text: ")
key = int(input("Enter key: "))

cipher = idea_encrypt(text, key)
print("Encrypted:", cipher)

plain = idea_decrypt(cipher, key)
print("Decrypted:", plain)
